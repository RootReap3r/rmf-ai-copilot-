# ─────────────────────────────────────────────────────────────────
# LLM PROVIDER CONFIGURATION
# Switch providers by changing these values only — no code changes.
# ─────────────────────────────────────────────────────────────────

# Which adapter to use:
#   "openai"     -> any OpenAI-compatible Chat Completions API
#                    (DeepSeek, vLLM, TGI, Ollama, most SIPR/NIPR
#                     internal LLM gateways, Azure OpenAI, etc.)
#   "anthropic"  -> native Anthropic Messages API format
#                    (api.anthropic.com OR an internal gateway that
#                     mirrors the Anthropic /v1/messages schema, e.g.
#                     some Bedrock proxies)
LLM_PROVIDER=openai

# Base URL for the API (no trailing slash)
#   DeepSeek:        https://api.deepseek.com
#   OpenAI:          https://api.openai.com/v1
#   Anthropic:       https://api.anthropic.com
#   AWS Bedrock:     use a Bedrock-compatible proxy URL, or switch
#                    to the bedrock adapter (see README)
#   SIPR/NIPR/FENCES: <your internal endpoint URL here>
LLM_BASE_URL=https://api.deepseek.com

# Model name as expected by that provider
#   DeepSeek:    deepseek-chat
#   OpenAI:      gpt-4o
#   Anthropic:   claude-sonnet-4-20250514
#   Internal:    <whatever your environment calls it>
LLM_MODEL=deepseek-chat

# API key / token for the above provider
LLM_API_KEY=sk-REPLACE_ME

# ─────────────────────────────────────────────────────────────────
# SERVER CONFIGURATION
# ─────────────────────────────────────────────────────────────────

# Port the backend listens on
PORT=3001

# Path to the local JSON storage file (persists tracker progress)
STORAGE_FILE=./data/storage.json
